          class="text-2xl md:text-3xl font-bold text-slate-100 tracking-wider"
        >
          Projects
        </h2>
        <div class="flex-1 h-px bg-gradient-to-r from-slate-800 to-transparent">
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          projectData.map((project) => (
            <a
              href={project.link}
              target="_blank"
              class={`block p-6 border border-slate-800/80 bg-slate-900/30 rounded-2xl transition-all duration-300 group ${project.theme === "sky" ? "hover:border-sky-500/50 hover:bg-slate-800/50" : "hover:border-purple-500/50 hover:bg-slate-800/30"}`}
            >
              {project.img ? (
                <div class="w-full h-48 mb-6 rounded-xl overflow-hidden bg-slate-800 relative">
                  <img
                    src={project.img}
                    alt={project.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
                  />
                  <div class="absolute inset-0 bg-slate-900/20 group-hover:bg-transparent transition-colors duration-500" />
                </div>
              ) : (
                <div
                  class={`w-full h-48 mb-6 rounded-xl overflow-hidden bg-slate-800/50 relative flex items-center justify-center border-2 border-dashed border-slate-700 transition-colors ${project.theme === "sky" ? "group-hover:border-sky-500/50" : "group-hover:border-purple-500/50"}`}
                >
                  <span
                    class={`font-mono text-sm transition-colors ${project.theme === "sky" ? "text-slate-500 group-hover:text-sky-400" : "text-slate-500 group-hover:text-purple-400"}`}
                  >
                    Image Space Reserved
                  </span>
                </div>
              )}

              <h3
                class={`text-xl font-bold text-slate-100 mb-3 transition-colors ${project.theme === "sky" ? "group-hover:text-sky-400" : "group-hover:text-purple-400"}`}
              >
                {project.title}
              </h3>
              <p class="text-sm text-slate-400 mb-8 leading-relaxed line-clamp-2">
                {project.desc}
              </p>

              <div class="flex gap-3">
                {project.tags.map((tag) => (
                  <span
                    class={`px-3 py-1.5 text-xs rounded-lg border font-medium ${project.theme === "sky" ? "bg-sky-500/10 text-sky-400 border-sky-500/20" : "bg-purple-500/10 text-purple-400 border-purple-500/20"}`}
                  >
                    {tag}
                  </span>
                ))}
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </div>

  <div
    id="tech-modal"
    class="fixed inset-0 bg-slate-950/80 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 backdrop-blur-md p-4"
  >
    <div
      class="bg-slate-900 border border-slate-700 rounded-2xl p-8 max-w-sm w-full relative shadow-2xl"
    >
      <button
        id="close-modal"
        class="absolute top-4 right-4 text-slate-500 hover:text-slate-300 transition-colors cursor-pointer"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path></svg
        >
      </button>
      <div class="flex items-center gap-5 border-b border-slate-800 pb-5 mb-5">
        <div
          id="modal-symbol"
          class="w-16 h-16 border-2 border-sky-500/50 rounded-xl flex items-center justify-center text-2xl font-bold font-mono text-sky-400 bg-slate-800/50"
        >
          --
        </div>
        <div>
          <h3
            id="modal-title"
            class="text-xl font-bold text-slate-100 tracking-wide"
          >
            技术名称
          </h3>
          <span class="text-xs text-slate-500 font-mono mt-1 block"
            >DATA_RECORD_ACCESSED</span
          >
        </div>
      </div>
      <p id="modal-desc" class="text-slate-400 text-sm leading-relaxed">
        详细描述。
      </p>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const techItems = document.querySelectorAll(".tech-item");
      const modal = document.getElementById("tech-modal")!;
      const closeModalBtn = document.getElementById("close-modal")!;
      const modalSymbol = document.getElementById("modal-symbol")!;
      const modalTitle = document.getElementById("modal-title")!;
      const modalDesc = document.getElementById("modal-desc")!;

      techItems.forEach((item) => {
        item.addEventListener("click", () => {
          const name = item.getAttribute("data-name");
          const symbol = item.getAttribute("data-symbol");
          const desc = item.getAttribute("data-desc");
          const theme = item.getAttribute("data-theme");

          modalTitle.textContent = name;
          modalSymbol.textContent = symbol;
          modalDesc.textContent = desc;

          modalSymbol.className = `w-16 h-16 border-2 rounded-xl flex items-center justify-center text-2xl font-bold font-mono bg-slate-800/50 
            ${
              theme === "sky"
                ? "border-sky-500/50 text-sky-400"
                : theme === "purple"
                  ? "border-purple-500/50 text-purple-400"
                  : theme === "emerald"
                    ? "border-emerald-500/50 text-emerald-400"
                    : "border-slate-500/50 text-slate-400"
            }`;

          modal.classList.remove("opacity-0", "pointer-events-none");
        });
      });

      const hideModal = () =>
        modal.classList.add("opacity-0", "pointer-events-none");
      closeModalBtn.addEventListener("click", hideModal);
      modal.addEventListener("click", (e) => {
        if (e.target === modal) hideModal();
      });
    });
  </script>
  <div
    id="pwd-modal"
    class="fixed inset-0 bg-slate-950/80 z-[60] flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 backdrop-blur-md p-4"
  >
    <div class="bg-slate-900 border border-indigo-500/30 rounded-2xl p-8 max-w-sm w-full relative shadow-[0_0_30px_rgba(99,102,241,0.15)] transform scale-95 transition-transform duration-300" id="pwd-modal-content">
      <button id="close-pwd-modal" class="absolute top-4 right-4 text-slate-500 hover:text-slate-300 transition-colors cursor-pointer">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
      
      <div class="flex flex-col items-center mb-6">
        <div class="w-12 h-12 bg-indigo-500/20 rounded-full flex items-center justify-center mb-4 border border-indigo-500/50 text-indigo-400">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-100 tracking-wide">系统访问受限</h3>
        <p class="text-xs text-slate-500 font-mono mt-1">PLEASE ENTER ACCESS CODE</p>
      </div>

      <div class="space-y-4">
        <input 
          type="password" 
          id="secret-input" 
          placeholder="•••" 
          class="w-full bg-black/40 border border-slate-700 rounded-lg px-4 py-3 text-center text-indigo-300 font-mono text-lg tracking-[0.5em] focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-all placeholder:tracking-normal placeholder:text-slate-600"
          autocomplete="off"
        />
        <p id="pwd-error" class="text-red-400 text-xs text-center h-4 opacity-0 transition-opacity">Access Denied: 密码错误</p>
        <button 
          id="submit-pwd"
          class="w-full py-3 bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg text-sm font-bold tracking-widest shadow-[0_0_15px_rgba(79,70,229,0.4)] transition-all active:scale-95"
        >
          AUTHENTICATE
        </button>
      </div>
    </div>
  </div>

  // 密码弹窗的 UI 和验证逻辑代码
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // ⚠️ 【配置区】：在这里设置你的专属密码
      const SECRET_PASSWORD = "Chemic@2026"; 

      const triggerBtn = document.getElementById("trigger-pwd-modal");
      const modal = document.getElementById("pwd-modal");
      const modalContent = document.getElementById("pwd-modal-content");
      const closeBtn = document.getElementById("close-pwd-modal");
      const submitBtn = document.getElementById("submit-pwd");
      const input = document.getElementById("secret-input") as HTMLInputElement;
      const errorMsg = document.getElementById("pwd-error");

      // 打开弹窗
      triggerBtn?.addEventListener("click", () => {
        modal?.classList.remove("opacity-0", "pointer-events-none");
        modalContent?.classList.remove("scale-95");
        modalContent?.classList.add("scale-100");
        input.value = "";
        errorMsg?.classList.add("opacity-0");
        setTimeout(() => input.focus(), 100); // 自动聚焦输入框
      });

      // 关闭弹窗
      const hideModal = () => {
        modal?.classList.add("opacity-0", "pointer-events-none");
        modalContent?.classList.remove("scale-100");
        modalContent?.classList.add("scale-95");
      };
      closeBtn?.addEventListener("click", hideModal);
      modal?.addEventListener("click", (e) => {
        if (e.target === modal) hideModal();
      });

      // 验证密码逻辑
      const verifyPassword = () => {
        if (input.value === SECRET_PASSWORD) {
          // 密码正确，在浏览器会话中做一个“已解锁”的标记
          sessionStorage.setItem("digital_garden_unlocked", "true");
          // 跳转到笔记页面
          window.location.href = "/notes";
        } else {
          // 密码错误，播放错误提示和震动动画
          errorMsg?.classList.remove("opacity-0");
          modalContent?.classList.add("animate-[shake_0.5s_ease-in-out]");
          setTimeout(() => {
            modalContent?.classList.remove("animate-[shake_0.5s_ease-in-out]");
          }, 500);
          input.value = "";
          input.focus();
        }
      };

      submitBtn?.addEventListener("click", verifyPassword);
      input?.addEventListener("keypress", (e) => {
        if (e.key === "Enter") verifyPassword();
      });
    });
  </script>

  <style>
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
      20%, 40%, 60%, 80% { transform: translateX(5px); }
    }
  </style>
</Layout>