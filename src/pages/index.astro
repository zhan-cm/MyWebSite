              data-name={tech.name}
              data-symbol={tech.symbol}
              data-desc={tech.desc}
              data-theme={tech.theme}
            >
              <span class="absolute top-1.5 left-1.5 text-[10px] text-slate-600 font-mono">
                {tech.id}
              </span>
              <span
                class={`text-xl md:text-2xl font-bold font-mono text-slate-400 group-hover:${getThemeClasses(tech.theme).split(" ").pop()} transition-colors`}
              >
                {tech.symbol}
              </span>
              <span class="text-[10px] md:text-xs text-slate-500 mt-1.5 truncate w-full text-center px-1 tracking-wider">
                {tech.name}
              </span>
            </div>
          ))
