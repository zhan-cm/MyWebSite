const getThemeClasses = (theme: string) => {
  const map: Record<string, string> = {
    sky: "border-slate-700/50 hover:border-sky-500 hover:bg-sky-500/10 text-sky-400",
    purple:
      "border-slate-700/50 hover:border-purple-400 hover:bg-purple-400/10 text-purple-400",
    emerald:
      "border-slate-700/50 hover:border-emerald-400 hover:bg-emerald-400/10 text-emerald-400",
    slate:
      "border-slate-700/50 hover:border-slate-300 hover:bg-slate-400/10 text-slate-300",
  };
  return map[theme] || map["slate"];
};

