---
import Layout from '../layouts/Layout.astro';

// ==========================================
// 【配置区：开发日志数据】
// 🌟 你的核心诉求：方便增删改！🌟
// 以后加新日志，只需在这个数组的最前面，复制一段 {} 照着改字就行。
// ==========================================
const logData = [
  {
    date: '2026-03-30', // 日期
    version: 'v2.0.0',  // 版本号 (可选)
    title: '全站重构', // 日志大标题
    content: [          // 日志内容 (数组里每一行会自动变成带有 > 箭头的列表)
      '抛弃旧版模板，全面拥抱 Astro + Tailwind CSS 现代前端架构。',
      '设计并实现了全新的赛博极客风“仪表盘”主控台。',
      '实现了完全数据驱动的技术栈周期表和番剧展示墙，维护成本大幅降低。'
    ],
    isLatest: true      // 设置为 true，这个节点就会有高亮发光的电光蓝特效！
  },
  {
    date: '2026-01-26',
    version: 'v1.0.2',
    title: '处理错误',
    content: [
      '处理了域名解析错误、端口占用等问题。',
      'SSL 部署问题以及本地和服务器远程连接的各种小问题均已解决。'
    ],
    isLatest: false
  },
  {
    date: '2026-01-15~2026-01-25',
    version: 'v1.0.1',
    title: '申请备案程序',
    content: [
      '申请中~~~'
    ],
    isLatest: false
  },
  {
    date: '2026-01-01~2026-01-05',
    version: 'v1.0.0',
    title: '个人网站开始二次开发',
    content: [
      '在别人开源的网站代码基础上下载并修改。',
      '成功部署到个人服务器上。',
      '虽然跑通了流程，但觉得风格不完全符合自己的极客审美，找时间重构。'
    ],
    isLatest: false
  }
];
---

<Layout title="日志 | Chemic.dev">
  <div class="max-w-4xl mx-auto px-4 md:px-6 py-10 space-y-8">

    <section class="flex items-center gap-3 pb-4 border-b border-slate-800/80">
      <svg class="w-6 h-6 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      <h1 class="text-xl md:text-2xl font-bold text-slate-100 tracking-wide">开发日志 / Changelog</h1>
    </section>

    <section class="relative">
      
      <div class="absolute left-4 md:left-8 top-2 bottom-2 w-px bg-gradient-to-b from-sky-500/50 via-slate-700/50 to-transparent"></div>

      <div class="space-y-12 py-4">
        {logData.map((log) => (
          <div class="relative pl-12 md:pl-20 group">
            
            <div class={`absolute left-[13px] md:left-[29px] top-1.5 w-3 h-3 rounded-full border-2 border-slate-950 shadow-[0_0_0_2px_rgba(15,23,42,1)] z-10 transition-colors duration-300 ${log.isLatest ? 'bg-sky-400 shadow-[0_0_15px_rgba(56,189,248,0.6)]' : 'bg-slate-600 group-hover:bg-slate-400'}`}></div>

            <div class={`p-6 border bg-slate-900/40 rounded-2xl transition-all duration-300 ${log.isLatest ? 'border-sky-500/30 shadow-[0_0_20px_rgba(56,189,248,0.05)]' : 'border-slate-800/80 hover:border-slate-700/80'}`}>
              
              <div class="flex flex-wrap items-center gap-3 mb-4">
                <span class="text-sky-400 font-mono text-sm font-bold flex items-center gap-1.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                  {log.date}
                </span>
                
                {log.version && (
                  <span class="px-2 py-0.5 bg-slate-800 text-slate-400 text-xs rounded border border-slate-700 font-mono">
                    {log.version}
                  </span>
                )}
                
                {log.isLatest && (
                  <span class="px-2 py-0.5 bg-sky-500/10 text-sky-400 text-xs rounded border border-sky-500/20 font-bold tracking-widest animate-pulse">
                    LATEST
                  </span>
                )}
              </div>

              <h3 class="text-lg font-bold text-slate-100 mb-4">{log.title}</h3>

              <div class="space-y-2.5">
                {log.content.map((line) => (
                  <p class="text-slate-400 text-sm leading-relaxed flex items-start gap-2.5">
                    <span class="text-slate-600 mt-0.5 select-none font-mono">></span>
                    <span>{line}</span>
                  </p>
                ))}
              </div>
              
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>
</Layout>